{
    "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": ["**", "!dist", "!pnpm-lock.yaml", "!.9flare-state.json"]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always",
            "trailingCommas": "all"
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "none",
            "correctness": {
                "noUnusedImports": "error",
                "useExhaustiveDependencies": "off"
            },
            "suspicious": {
                "noConsole": "off",
                "noExplicitAny": "error"
            },
            "style": {
                "noNonNullAssertion": "error",
                "useConst": "error",
                "useImportType": "error",
                "useTemplate": "error"
            }
        }
    }
}
